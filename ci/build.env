# CI runtime settings. Release-backed tools: leave version empty = latest semver GitHub tag.

JAVA_VERSION=17
NODE_VERSION=24

MC_VERSION=1.20.1
MC_ASSET_INDEX=5
FORGE_BUILD=47.4.13

MODPACK_DIR=Modpack-Modern
MODPACK_REPO=https://github.com/TerraFirmaGreg-Team/Modpack-Modern.git
MODPACK_TAG=

FQE_REPO=jmecn/ftb-quest-export
FQE_VERSION=

SITE_VIEWER_REPO=jmecn/QuestBook-React
SITE_VIEWER_VERSION=

HMC_REPO=3arthqu4ke/headlessmc
HMC_VERSION=2.9.0

# Export locales: language.json enabledLocales → -Dquest.exportLanguages=...

EXPORT_WARMUP_TICKS=100
EXPORT_WORLD_DELAY_TICKS=600
EXPORT_TIMEOUT_SECONDS=7200

# Export bundle cache: key ${EXPORT_CACHE_KEY_PREFIX}-<bundle_id>-<export_fingerprint>
# export_fingerprint = sha256(modpack:fqe) first 8 hex chars
# Paths: export-meta/ + quest-export-<bundle_id>.tar.gz at workspace root.
EXPORT_CACHE_KEY_PREFIX=quest-export

# Legacy artifact name (local fetch-bundle debugging only).
EXPORT_ARTIFACT_NAME=quest-book
EXPORT_WORKFLOW_NAME="Build quest book"

EXPORT_ROOT_DIR=export
QUEST_SUBDIR=quest-export
SITE_OUTPUT_DIR=site

# GitHub Release tar for Wiki aggregation (tag + contentHash are written to build.json).
SITE_RELEASE_ASSET_NAME=quest-book-site.tar.gz
SITE_RELEASE_HASH_LENGTH=7

# Published build gate: last successful deploy versions at this URL.
# Empty = https://<owner>.github.io/<repo>/build.json from GITHUB_REPOSITORY.
BUILD_JSON_URL=

# Cross-site bases for deploy site-config.json (trailing slash; no query — React adds lang/item/tag).
RECIPE_BOOK_BASE_URL=https://wiki.terrafirmagreg.team/recipe-book-modern/
FIELD_GUIDE_BASE_URL=https://wiki.terrafirmagreg.team/field-guide-modern/
SITE_BASE_URL=https://wiki.terrafirmagreg.team/quest-book-modern/

RUNNER_HOME=/home/runner
